// Doit Agent Context: Tool Use Scenario (Multi-Turn Stage 2 - adds clarification)
//
// Entry point: BashToolAgent.run_single (tool_calling = true).
// Stage 2 layers the clarification feature on top of Stage 1. Per user turn @T the LLM
// contexts are, in order:
//   1) HistoryReferenceResolver - picks which prior turns are relevant     (unchanged vs Stage 1)
//   2) DoitToolUseAgent         - generates a command OR asks for clarification; now seeded with
//                                 in-context few-shot demos and re-invoked once per clarification step @T.i
//   3) ClarificationAuthor      - NEW: focused call that AUTHORS the clarifying question whenever
//                                 the agent calls ask_user_clarification
//   4) BashFilter               - judges whether the final command modifies the filesystem (unchanged)
//
// Notation: @T is the current turn; a step i WITHIN turn @T is written @T.i (the new within-turn
// axis). Clarification is bounded to MAX_CLARIFICATION_ROUNDS (= 2) steps per turn.
// Across turns nothing changes vs Stage 1: the chosen answer is FOLDED into the stored prompt
// (e.g. "<instruction> [clarified: <answer>]"), so replayed history carries only that folded
// prompt - the question/answer exchange itself is never replayed.
//
// Convention: range(1, @T) and any index < @T refer to prior turns; @T is the current turn.


// 1. History Reference Resolver (_analyze_references) - unchanged from Stage 1.
//    One user message: the new instruction plus prior command history as metadata only
//    (id, prompt, command - NO output), last 20 turns, command-bearing only, newest-first.
//    Skipped (no LLM context) when the instruction has no contextual indicator word.
HistoryReferenceResolver[@T]: {
    S: {
        sys.history_system_instruction
    }

    U: {
        env.user_input[@T]
        sys.pid.history_metadata_reversed[@T]   // newest-first; command-bearing turns only; fields: [id, prompt, command]
    }
}


// 2. Doit Main Agent (DoitToolUseAgent)
//    System prompt + native tool schema, then fixed in-context few-shot demonstrations of the
//    ask-vs-execute decision, then the replayed relevant history, then the new instruction, then
//    a bounded clarification loop. The agent is invoked once per clarification step @T.i.
DoitToolUseAgent[@T]: {
    S: {
        sys.doit_system_prompt
        sys.tools_definition                    // execute_bash_command AND ask_user_clarification schemas
    }

    // Injected few-shot demonstrations (FEWSHOT_TOOLCALL): standalone message turns appended AFTER
    // the system message and BEFORE the history. Each demo is a triple. Fixed every turn; teaches
    // the decision (clear -> execute_bash_command, ambiguous -> ask_user_clarification).
    ForEach(@d: sys.fewshot_toolcall) {
        U: sys.fewshot_toolcall[@d].instruction
        A: sys.fewshot_toolcall[@d].tool_call   // execute_bash_command OR ask_user_clarification call
        T: sys.fewshot_toolcall[@d].result      // command output, or the clarification answer
    }

    // Replayed relevant history (resolved + transitively chained ids), ascending order. Same as
    // Stage 1; the prompt may already carry a folded "[clarified: <answer>]" suffix.
    ForEach(@t: resp.pid.history_reference_resolver[@T].relevant_ids) {
        U: sys.pid.turn[@t].prompt
        If(sys.pid.turn[@t].command != "") {
            A: sys.pid.tool_call[@t]            // execute_bash_command tool call
            T: sys.pid.turn[@t].output          // tool result; truncated to 2000 chars
        } Else {
            A: sys.pid.turn[@t].output          // turn produced no command: plain assistant message
        }
    }

    U: env.user_input[@T]

    // Bounded clarification loop (at most MAX_CLARIFICATION_ROUNDS rounds). On each round the agent
    // is re-invoked; while it chooses to ask, the question authored by ClarificationAuthor is put to
    // the user and the answer is fed back as a tool result, then the agent runs again. On the final
    // round the ask_user_clarification tool is withdrawn, forcing a command.
    ForEach(i: pid.clarification_steps[@T]) {   // i = step within turn @T; bounded by MAX_CLARIFICATION_ROUNDS (2)
        If(resp.pid.doit_tool_use_agent[@T.i].asks_clarification) {
            A: resp.pid.doit_tool_use_agent[@T.i].ask_user_clarification_call   // tool call; optional "reason" arg
            T: env.user_clarification_answer[@T.i]   // user's answer (menu pick mapped to text, or no-answer sentinel), restated via _clarification_followup
        }
    }
    // The loop ends when the agent emits an execute_bash_command call (handled by BashFilter below).
}


// 3. Clarification Author (_author_clarification) - NEW in Stage 2.
//    Invoked at step @T.i whenever the agent decides to ask. A focused single-purpose call: model
//    and endpoint are read from doit.cfg, and it authors the actual clarifying question (and
//    optional options) from the instruction alone. Its output drives the interactive menu shown to
//    the user; the user's reply becomes env.user_clarification_answer[@T.i] consumed above.
ClarificationAuthor[@T.i]: {
    S: {
        sys.clarify_author_prompt
    }

    U: env.user_input[@T]                       // only the instruction; returns a question plus optional options
}


// 4. Bash Filter (_filter_bash) - unchanged from Stage 1.
//    Invoked only when the agent finally emits an execute_bash_command call. One user message:
//    the fixed question concatenated with the generated command. Classifies DECISION: YES / NO.
BashFilter[@T]: {
    S: {
        sys.doit_filter_prompt
    }

    U: {
        sys.filter_user_instruction             // "Does the following command modify the file system?"
        resp.pid.doit_tool_use_agent[@T].tool_call[0].command   // command arg of the final execute_bash_command call
    }
}
