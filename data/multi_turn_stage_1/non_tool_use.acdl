// Doit Agent Context: Non-Tool Use / Fallback JSON Scenario (Multi-Turn Stage 1)
//
// Entry point: BashToolAgent.run_single (tool_calling = false). The model has no native
// tool calling, so it must emit a raw fallback-JSON block and execution output is fed back
// as a USER message. To keep STRICTLY alternating user/assistant roles, each turn's output
// is folded into the FOLLOWING user message instead of being sent on its own.
//
// Same three sequential contexts as the tool-use scenario.

// 1. History Reference Resolver: Identifies relevant prior turns at time step t
HistoryReferenceResolver[@T]: {
    // S: System instructions for history reference resolution
    S: {
        sys.history_system_instruction
    }

    U: {
        env.user_input[@T]
        
    }
        ForEach(@t: range(1, @T-1)){
        U: {
            sys.history_ppid_metadata[@t]
        }
    }
}

// 2. Doit Main Agent: Generates command at time step t using loaded history context
DoitNonToolUseAgent[@T]: {
    // S: System instructions appended with Fallback JSON instructions
    S: {
        sys.doit_system_prompt
        sys.fallback_system_instruction
    }

    // U: Reconstructed history of transitively resolved relevant turns [1..k] in alternating user-assistant roles
    ForEach(@t: sys.relevant_ids[@T]) {
        U: sys.turn[@t].prompt
        If(sys.turn[@t].command != "") {
            A: sys.tool_call[@t]            // execute_bash_command tool call; args: command = sys.turn[@t].command, explanation = "execute <command>"
            T: sys.turn[@t].output          // tool result; truncated to 2000 chars
        } Else {
            A: sys.turn[@t].output          // turn produced no command: replayed as a plain assistant message
        }
    }   
        U: env.user_input[@T]
}


// 3. Bash Filter: Runs synchronously if a filesystem-modifying command was generated
BashFilter[@T]: {
    // S: Instructions to classify if the command modifies the filesystem
    S: {
        sys.doit_filter_prompt
    }

    U: {
        sys.filter_user_instruction
        resp.doit_non_tool_use_agent_response[@T].command
    }
}
