// Doit Agent Context: Non-Tool Use / Fallback JSON Scenario (Multi-Turn Stage 1)
//
// Entry point: BashToolAgent.run_single (tool_calling = false). The model has no native
// tool calling, so it must emit a raw fallback-JSON block and execution output is fed back
// as a USER message. To keep STRICTLY alternating user/assistant roles, each turn's output
// is folded into the FOLLOWING user message instead of being sent on its own.
//
// Each user turn at step @T issues up to three sequential LLM contexts, in order:
//   1) HistoryReferenceResolver - picks which prior turns are relevant
//   2) DoitNonToolUseAgent      - generates the command with the reconstructed history
//   3) BashFilter               - judges whether that command modifies the filesystem
//
// Convention: range(1, @T) and any index < @T refer to prior turns; @T is the current turn.


// 1. History Reference Resolver (_analyze_references)
//    One user message: the new instruction plus the prior command history as metadata
//    only (id, prompt, command - NO output), capped at the last 20 turns, filtered to
//    turns whose command != "", and listed newest-first.
//    (When the instruction contains no contextual indicator word the resolver is skipped
//    and the relevant set is empty; that fast path issues no LLM context.)
HistoryReferenceResolver[@T]: {
    S: {
        sys.history_system_instruction
    }

    U: {
        env.user_input[@T]
        sys.pid.history_metadata_reversed[@T]   // newest-first; command-bearing turns only; fields: [id, prompt, command], this is generated by the system
    }
}


// 2. Doit Main Agent (DoitNonToolUseAgent)
//    System prompt + fallback-JSON instructions, then the reconstructed history of the
//    resolved relevant turns (with their transitive dependencies), then the new instruction.
//    Each relevant turn replays as: user prompt -> assistant tool call -> tool result.
DoitNonToolUseAgent[@T]: {
    S: {
        sys.doit_system_prompt
        sys.fallback_system_instruction
    }

    // Resolved + transitively chained relevant turn ids, ascending order.
    ForEach(@t: resp.pid.history_reference_resolver[@T].relevant_ids) { // @t is a resolved relevant turn id, ascending order
        U: sys.pid.turn[@t].prompt

        If(sys.pid.turn[@t].command != "") {
            A: sys.pid.tool_call[@t]            // execute_bash_command tool call; args: command = sys.pid.turn[@t].command, explanation = "execute <command>"
            T: sys.pid.turn[@t].output          // tool result; truncated to 2000 chars
        } Else {
            A: sys.turn[@t].output              // turn produced no command: replayed as a plain assistant message
        }
    }

    U: env.user_input[@T]
}


// 3. Bash Filter (_filter_bash)
//    Invoked only when the main agent emits a command. One user message: the fixed
//    question concatenated with the generated command. Classifies DECISION: YES / NO. Determines whether the command modifies the filesystem. If YES, the command is executed.
BashFilter[@T]: {
    S: {
        sys.doit_filter_prompt
    }

    U: {
        sys.filter_user_instruction         // "Does the following command modify the file system?"
        resp.doit_non_tool_use_agent[@T].command   // command field of the fallback-JSON object emitted by the agent, when present (i.e., when the agent emitted a command)
    }
}
